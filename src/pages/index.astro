---
import { Code } from "astro:components";
import Base from "../layouts/Base.astro";
import DagDiagram from "../components/DagDiagram.astro";
import CopyBlock from "../components/CopyBlock.astro";
import { toolGroups, corePackages, packageCount } from "../data/tools.ts";

const heroSnippet = `import { Build, cicd, run, target } from "jsr:@zuke/core";
import { DenoTasks } from "jsr:@zuke/deno";

class MyBuild extends Build {
  // declare a pipeline → generates .github/workflows
  ci = cicd({ provider: "github" });

  compile = target()
    .description("Type-check & bundle")
    .dependsOn(this.clean, this.restore)
    .executes(async () => {
      await DenoTasks.check((s) => s.paths("mod.ts"));
    });
}

await run(MyBuild);`;

const shellSnippet = `// The $ tagged template runs processes safely — no shell injection.
const sha = await $\`git rev-parse HEAD\`.text();   // trimmed stdout
await $\`deno test -A\`;                              // throws on non-zero
const code = await $\`flaky-cmd\`.noThrow().code();   // never throws`;

const features = [
  {
    icon: "type",
    title: "Typed, refactor-safe dependencies",
    body: "Targets reference each other with this.target — not magic strings. Rename one and every reference updates. The compiler has your back.",
  },
  {
    icon: "code",
    title: "Just TypeScript",
    body: "Build logic is ordinary async functions with full editor support, types, and debugging. No YAML, no bespoke DSL to learn.",
  },
  {
    icon: "graph",
    title: "Automatic topological order",
    body: "Declare what each target depends on; Zuke resolves the graph and runs everything in the right order, exactly once.",
  },
  {
    icon: "ci",
    title: "Code-first CI/CD",
    body: "Declare pipelines with cicd() and generate GitHub Actions, GitLab CI, or Azure Pipelines YAML — verified up to date on every run.",
  },
  {
    icon: "shell",
    title: "Ergonomic, safe shell",
    body: "The $ tagged template executes processes with sensible defaults and prevents injection — capture output, ignore failures, or fail fast.",
  },
  {
    icon: "bolt",
    title: "Incremental & parallel",
    body: "Zuke caches target results and skips unchanged work, and runs independent targets concurrently with --parallel.",
  },
  {
    icon: "jsr",
    title: "A typed tool ecosystem",
    body: `Strongly-typed wrappers for ${packageCount}+ tools — Deno, npm, Bun, Docker, Kubernetes, Helm, Vite, Playwright, Terraform and more — all on JSR.`,
  },
  {
    icon: "ai",
    title: "AI in your pipeline",
    body: "Typed wrappers for Claude Code, OpenAI Codex, and Gemini CLI run headless in CI — drive a prompt, pick a model, constrain the tools, and capture the output, injection-free.",
  },
  {
    icon: "review",
    title: "AI code-review gate",
    body: "Turn an LLM into a build gate with @zuke/ai — it reads the diff, gets a structured risk assessment, and breaks the build when the score crosses your threshold. Claude, OpenAI, or Gemini.",
  },
  {
    icon: "announce",
    title: "Announce to chat",
    body: "Post build status to Slack, Microsoft Teams, and Discord from a target with AnnounceTasks — typed messages with levels, fields, and links, over incoming webhooks or each platform's bot API.",
  },
  {
    icon: "plugin",
    title: "Extensible by design",
    body: "Need a tool we don't wrap yet? Extend ToolSettings from @zuke/core/tooling to build your own typed wrapper — no fork required.",
  },
  {
    icon: "zero",
    title: "Zero runtime dependencies",
    body: "Zuke ships on Deno with nothing else to install. The bootstrap launcher even installs Deno for you on first run.",
  },
];

const icons: Record<string, string> = {
  type: `<path d="M4 7V5h16v2M9 5v14m-3 0h6"/>`,
  code: `<path d="m8 8-4 4 4 4M16 8l4 4-4 4"/>`,
  graph: `<circle cx="5" cy="6" r="2.5"/><circle cx="5" cy="18" r="2.5"/><circle cx="13" cy="12" r="2.5"/><circle cx="20" cy="12" r="2.5"/><path d="M7 7.5 10.7 11M7 16.5 10.7 13M15.5 12H17.5"/>`,
  ci: `<path d="M4 6a2 2 0 1 1 4 0 2 2 0 0 1-4 0Zm12 12a2 2 0 1 1 4 0 2 2 0 0 1-4 0ZM6 8v4a4 4 0 0 0 4 4h4"/><path d="M14 14l2 2-2 2"/>`,
  shell: `<path d="m5 8 4 4-4 4M12 16h7"/><rect x="2" y="3" width="20" height="18" rx="3"/>`,
  bolt: `<path d="M13 2 4 14h7l-1 8 9-12h-7z"/>`,
  zero: `<path d="M20 7 12 3 4 7v10l8 4 8-4z"/><path d="M12 12 4 7M12 12v9M12 12l8-5"/>`,
  jsr: `<path d="M4 6h16v12H4z"/><path d="M8 10v4M12 9v6M12 15h2a2 2 0 0 0 0-4M16 10h2"/>`,
  plugin: `<path d="M9 3v4M15 3v4M7 7h10v4a5 5 0 0 1-10 0zM12 16v5"/>`,
  ai: `<rect x="4" y="7" width="16" height="12" rx="2.5"/><path d="M12 7V4M9 12h.01M15 12h.01M9 15.5h6"/><path d="M2 12h2M20 12h2"/>`,
  announce: `<path d="M3 11v2a1 1 0 0 0 1 1h2l4 4V6L6 10H4a1 1 0 0 0-1 1Z"/><path d="M15 9a4 4 0 0 1 0 6M18 6.5a8 8 0 0 1 0 11"/>`,
  review: `<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/><path d="m9 14 2 2 4-4"/>`,
};

// The model providers @zuke/ai supports, shown as chips in the AI review section.
const providers = [
  {
    name: "Claude",
    color: "#d97757",
    // sunburst asterisk
    svg: `<path d="M12 3v18M3 12h18M5.6 5.6l12.8 12.8M18.4 5.6 5.6 18.4"/>`,
  },
  {
    name: "OpenAI",
    color: "#10a37f",
    // hexagon with a node
    svg: `<path d="M12 3.2 18.9 7.1v9.8L12 20.8 5.1 16.9V7.1z"/><circle cx="12" cy="12" r="2.6"/>`,
  },
  {
    name: "Gemini",
    color: "#4f8cff",
    // four-point sparkle
    svg: `<path d="M12 2c.5 5.5 4 9 9.5 9.5-5.5.5-9 4-9.5 9.5-.5-5.5-4-9-9.5-9.5C8 11 11.5 7.5 12 2Z"/>`,
  },
];
---

<Base>
  <!-- ░░ HERO ░░ -->
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__copy">
        <span class="eyebrow">Build automation · Deno &amp; TypeScript</span>
        <h1 class="hero__title">
          Builds you can <span class="gradient-text">refactor</span>,
          not just run.
        </h1>
        <p class="lead">
          Zuke is a code-first, strongly-typed build system. Define targets as
          TypeScript class fields, wire dependencies with a fluent API, and let
          Zuke resolve and run them in topological order — with zero runtime
          dependencies.
        </p>
        <div class="hero__cta">
          <a class="btn btn-primary" href="/docs">Get started →</a>
          <a class="btn btn-ghost" href="https://github.com/zuke-build/zuke">
            View on GitHub
          </a>
        </div>
        <div class="hero__install">
          <CopyBlock
            label="Install the CLI"
            lines={[
              "deno install -A -g -n zuke jsr:@zuke/cli",
              "zuke setup",
              "./zuke",
            ]}
          />
        </div>
      </div>

      <div class="hero__code" data-reveal>
        <div class="codecard panel">
          <div class="codecard__bar">
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__name">zuke.ts</span>
          </div>
          <Code code={heroSnippet} lang="ts" theme="night-owl" />
        </div>
      </div>
    </div>

    <div class="container hero__strip">
      <span><b>v1</b> on the horizon</span>
      <span class="dotsep">•</span>
      <span>Deno-native</span>
      <span class="dotsep">•</span>
      <span>Zero runtime deps</span>
      <span class="dotsep">•</span>
      <span>Published on JSR</span>
      <span class="dotsep">•</span>
      <span>Inspired by NUKE for .NET</span>
    </div>
  </section>

  <!-- ░░ FEATURES ░░ -->
  <section class="section" id="features">
    <div class="container">
      <header class="sec-head">
        <span class="eyebrow">Why Zuke</span>
        <h2>Everything a build needs — typed end to end.</h2>
      </header>
      <div class="feat-grid">
        {features.map((f) => (
          <article class="feat panel" data-reveal>
            <span class="feat__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
                stroke-linejoin="round" set:html={icons[f.icon]} />
            </span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ DAG / RESOLUTION ░░ -->
  <section class="section sec-dag" id="resolution">
    <div class="container dag-grid">
      <div data-reveal>
        <span class="eyebrow">Topological resolution</span>
        <h2>Declare dependencies.<br />Zuke figures out the order.</h2>
        <p class="lead">
          Each target lists what it <code>dependsOn</code>. Zuke builds the
          dependency graph, runs independent targets as far as it can, and
          executes everything exactly once in the correct order.
        </p>
        <ul class="ticks">
          <li>References are real values — <code>this.build</code>, never a string.</li>
          <li>Per-target status, timing, and a final build summary.</li>
          <li>Rename a target and every dependant updates automatically.</li>
        </ul>
        <p class="dag-note">↓ This is the actual graph that builds this website.</p>
      </div>
      <div data-reveal>
        <DagDiagram />
      </div>
    </div>
  </section>

  <!-- ░░ OUTPUT ░░ -->
  <section class="section sec-out" id="output">
    <div class="container out-grid">
      <div data-reveal>
        <span class="eyebrow">Readable output</span>
        <h2>A build log you can actually scan.</h2>
        <p class="lead">
          Every target is framed with a ruled banner and closes with a plain
          pass/fail line and its duration. The run ends with an aligned
          <strong>Build Summary</strong> — status and timing per target, a total,
          and a one-line verdict stamped with the time.
        </p>
        <ul class="ticks">
          <li>Blocks are easy to scan; a failure prints its error inline.</li>
          <li>The summary table totals the wall-clock time across targets.</li>
          <li>GitHub Actions gets matching groups, annotations, and a job-summary table.</li>
        </ul>
      </div>
      <div data-reveal>
        <div class="codecard panel">
          <div class="codecard__bar">
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__name">zuke build</span>
          </div>
<pre class="term"><span class="t-cmd">$ ./zuke build</span>

<span class="t-banner">══════════════════════════════</span>
<span class="t-name">build</span>
<span class="t-banner">══════════════════════════════</span>
<span class="t-dim">  ▸ astro build — 4 pages in 2.2s</span>
<span class="t-ok">✔</span> build <span class="t-dim">succeeded in 2.2s</span>

<span class="t-title">Build Summary</span>
<span class="t-rule">────────────────────────────</span>
<span class="t-head">Target   Status     Duration</span>
<span class="t-rule">────────────────────────────</span>
clean    <span class="t-ok">Succeeded</span>      0.1s
install  <span class="t-ok">Succeeded</span>     12.4s
check    <span class="t-ok">Succeeded</span>      3.1s
build    <span class="t-ok">Succeeded</span>      2.2s
<span class="t-rule">────────────────────────────</span>
<span class="t-total">Total                  17.8s</span>

<span class="t-pass">✔ Build succeeded — 4/4 targets in 17.8s · 2026-06-23 07:19</span></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ SHELL ░░ -->
  <section class="section" id="shell">
    <div class="container shell-grid">
      <div class="codecard panel" data-reveal>
        <div class="codecard__bar">
          <span class="codecard__dot"></span>
          <span class="codecard__dot"></span>
          <span class="codecard__dot"></span>
          <span class="codecard__name">shell.ts</span>
        </div>
        <Code code={shellSnippet} lang="ts" theme="night-owl" />
      </div>
      <div data-reveal>
        <span class="eyebrow">The $ shell</span>
        <h2>Run processes without the footguns.</h2>
        <p class="lead">
          The <code>$</code> tagged template from <code>@zuke/core/shell</code>
          escapes interpolations automatically, so untrusted values can't break
          out of a command. Chain <code>.text()</code>, <code>.code()</code>, or
          <code>.noThrow()</code> for exactly the behaviour you want.
        </p>
        <a class="btn btn-ghost" href="/docs">Read the shell guide →</a>
      </div>
    </div>
  </section>

  <!-- ░░ AI REVIEW ░░ -->
  <section class="section sec-review" id="ai-review">
    <div class="container review-grid">
      <div data-reveal>
        <span class="eyebrow">AI code review <span class="tag-new">New</span></span>
        <h2>Let a model <span class="gradient-text">gate the build</span>.</h2>
        <p class="lead">
          <code>@zuke/ai</code> attaches an AI reviewer to a target as a
          validation. It reads the diff, asks the model for a
          <strong>structured risk assessment</strong>, and breaks the build when
          the score crosses your threshold — a real verdict your pipeline can
          branch on, not a blob of prose.
        </p>
        <ul class="ticks">
          <li>Security, secrets, correctness, licensing — or your own <code>.criteria()</code>.</li>
          <li>Claude, OpenAI, or Gemini, with the JSON shape enforced server-side.</li>
          <li>Gate with <code>.validateBefore()</code>; findings land in the CI job summary.</li>
          <li><code>.comment()</code> upserts the verdict as a pull-request comment.</li>
        </ul>
        <div class="providers">
          <span class="providers__label">Works with</span>
          {providers.map((p) => (
            <span class="provider" style={`--c:${p.color}`}>
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="1.8" stroke-linecap="round"
                stroke-linejoin="round" set:html={p.svg} />
              {p.name}
            </span>
          ))}
        </div>
        <a class="btn btn-ghost" href="/docs/ai-review">Read the AI review guide →</a>
      </div>
      <div data-reveal>
        <div class="review panel">
          <div class="review__head">
            <span class="review__name">🛡 securityReviewer</span>
            <span class="review__verdict">✘ Build blocked</span>
          </div>
          <div class="review__score">
            <span class="review__num">8<small>/10</small></span>
            <div class="review__meta">
              <span class="sevtag sevtag--high">HIGH</span>
              <span class="review__cap">risk score · threshold 7</span>
            </div>
          </div>
          <div class="review__meter"><span style="width:80%"></span></div>
          <ul class="review__findings">
            <li><span class="sevtag sevtag--high">HIGH</span> Hard-coded API token in <code>src/config.ts:42</code></li>
            <li><span class="sevtag sevtag--med">MED</span> Unvalidated redirect in <code>routes/login.ts</code></li>
            <li><span class="sevtag sevtag--low">LOW</span> Stack trace leaked in error response</li>
          </ul>
          <p class="review__foot">via @zuke/ai · claude-opus-4-8 · tokens: 1234 in · 567 out · 1801 total</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ TOOLS ░░ -->
  <section class="section sec-tools" id="tools">
    <div class="container">
      <header class="sec-head">
        <span class="eyebrow">The @zuke ecosystem · {packageCount} packages</span>
        <h2>Typed wrappers for the tools you already use.</h2>
        <p class="lead sec-head__lead">
          Every wrapper is a fluent, strongly-typed API over a real CLI —
          published to JSR, tree-shakeable, and refactor-safe. And if one's
          missing, you can write your own.
        </p>
      </header>

      <div class="tools-grid">
        {toolGroups.map((g) => (
          <article class="toolcard panel" data-reveal>
            <h3 class="toolcard__cat">{g.category}</h3>
            <p class="toolcard__blurb">{g.blurb}</p>
            <ul class="toolcard__list">
              {g.tools.map((t) => (
                <li>
                  <span class="toolcard__name">{t.name}</span>
                  <code class="toolcard__pkg">{t.pkg}</code>
                  <span class="toolcard__desc">{t.desc}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <div class="core-row panel" data-reveal>
        <span class="core-row__h">The engine</span>
        <div class="core-row__items">
          {corePackages.map((p) => (
            <div class="core-pkg">
              <code>{p.name}</code>
              <span>{p.desc}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ CTA ░░ -->
  <section class="section">
    <div class="container">
      <div class="cta panel" data-reveal>
        <h2>Ship your first typed build in minutes.</h2>
        <p>Install the CLI, scaffold a <code>zuke.ts</code>, and run your first target.</p>
        <CopyBlock
          lines={[
            "deno install -A -g -n zuke jsr:@zuke/cli",
            "zuke setup",
            "./zuke --list",
          ]}
        />
        <div class="cta__btns">
          <a class="btn btn-primary" href="/docs">Read the docs →</a>
          <a class="btn btn-ghost" href="/examples">Browse examples</a>
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  /* hero */
  .hero { padding-top: clamp(48px, 8vw, 96px); }
  .hero__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 52px;
    align-items: center;
  }
  .hero__title {
    font-size: clamp(2.3rem, 5vw, 3.6rem);
    font-weight: 800;
    margin-bottom: 20px;
  }
  .hero__cta {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    margin: 28px 0 26px;
  }
  .hero__install { max-width: 460px; }

  .hero__strip {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 14px;
    margin-top: 64px;
    padding-top: 26px;
    border-top: 1px solid var(--border);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-faint);
  }
  .hero__strip b { color: var(--cyan); font-weight: 700; }
  .dotsep { color: var(--border); }

  /* code card */
  .codecard { overflow: hidden; box-shadow: var(--shadow-glow); }
  .codecard__bar {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 11px 15px;
    border-bottom: 1px solid var(--border);
    background: rgba(255, 255, 255, 0.015);
  }
  .codecard__dot { width: 11px; height: 11px; border-radius: 99px; background: #2a3559; }
  .codecard__dot:nth-child(1) { background: #ff5f56; }
  .codecard__dot:nth-child(2) { background: #ffbd2e; }
  .codecard__dot:nth-child(3) { background: #27c93f; }
  .codecard__name {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-faint);
  }
  .codecard :global(pre.astro-code) {
    border: 0 !important;
    border-radius: 0;
    margin: 0;
  }

  /* section heads */
  .sec-head { text-align: center; max-width: 640px; margin: 0 auto 48px; }
  .sec-head h2 { font-size: clamp(1.7rem, 3.4vw, 2.4rem); }
  .sec-head__lead { margin-inline: auto; }

  /* features */
  .feat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .feat { padding: 26px 24px; transition: transform 0.2s ease, border-color 0.2s ease; }
  .feat:hover { transform: translateY(-3px); border-color: #2c3760; }
  .feat__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: var(--gradient-soft);
    color: var(--cyan);
    margin-bottom: 16px;
  }
  .feat h3 { font-size: 1.08rem; margin-bottom: 8px; }
  .feat p { font-size: 0.93rem; margin: 0; }

  /* output */
  .out-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 48px;
    align-items: center;
  }
  .out-grid h2 { font-size: clamp(1.7rem, 3.2vw, 2.3rem); }
  .term {
    margin: 0;
    padding: 18px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    line-height: 1.55;
    color: var(--text-dim);
    overflow-x: auto;
    white-space: pre;
    tab-size: 2;
  }
  .term .t-cmd { color: var(--text-faint); }
  .term .t-banner, .term .t-rule { color: #2c3760; }
  .term .t-name { color: var(--cyan); font-weight: 700; }
  .term .t-dim { color: var(--text-faint); }
  .term .t-ok { color: #41d18a; }
  .term .t-title, .term .t-total { color: var(--text); font-weight: 700; }
  .term .t-head { color: var(--text-dim); font-weight: 700; }
  .term .t-pass { color: #41d18a; font-weight: 700; }

  /* dag */
  .sec-dag { background: linear-gradient(180deg, transparent, rgba(11,14,23,0.5), transparent); }
  .dag-grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 48px;
    align-items: center;
  }
  .dag-grid h2 { font-size: clamp(1.7rem, 3.2vw, 2.3rem); }
  .ticks { list-style: none; padding: 0; margin: 20px 0 0; display: grid; gap: 12px; }
  .ticks li {
    position: relative;
    padding-left: 30px;
    color: var(--text-dim);
    font-size: 0.95rem;
  }
  .ticks li::before {
    content: "";
    position: absolute;
    left: 0; top: 2px;
    width: 18px; height: 18px;
    border-radius: 6px;
    background: var(--gradient-soft);
    border: 1px solid var(--cyan);
  }
  .ticks li::after {
    content: "✓";
    position: absolute;
    left: 4px; top: 1px;
    color: var(--cyan);
    font-size: 0.75rem;
    font-weight: 700;
  }
  .dag-note {
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--text-faint);
  }

  /* shell */
  .shell-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 48px;
    align-items: center;
  }
