---
import { Code } from "astro:components";
import Base from "../layouts/Base.astro";
import DagDiagram from "../components/DagDiagram.astro";
import CopyBlock from "../components/CopyBlock.astro";
import { toolGroups, corePackages, packageCount } from "../data/tools.ts";

const heroSnippet = `import { Build, cicd, run, target } from "jsr:@zuke/core";
import { DenoTasks } from "jsr:@zuke/deno";

class MyBuild extends Build {
  // declare a pipeline → generates .github/workflows
  ci = cicd({ provider: "github" });

  compile = target()
    .description("Type-check & bundle")
    .dependsOn(this.clean, this.restore)
    .executes(async () => {
      await DenoTasks.check((s) => s.paths("mod.ts"));
    });
}

await run(MyBuild);`;

const shellSnippet = `// The $ tagged template runs processes safely — no shell injection.
const sha = await $\`git rev-parse HEAD\`.text();   // trimmed stdout
await $\`deno test -A\`;                              // throws on non-zero
const code = await $\`flaky-cmd\`.noThrow().code();   // never throws`;

const consoleSnippet = `import { ConsoleTasks as Log } from "jsr:@zuke/console";

Log.rule("Release");
Log.info("pushing [bold]core@1.2.0[/]");        // markup: [tag]…[/]
Log.success("[green]✔[/] published 4 packages");
Log.warn("coverage [yellow]94.2%[/] — below gate");

Log.box(["core  1.2.0  ✔", "cli   1.2.0  ✔"], {
  title: "Artifacts",
  border: ["green"],
});

Log.table(
  [{ header: "Package" }, { header: "Size", align: "right" }],
  [["@zuke/core", "18 kB"], ["@zuke/cli", "12 kB"]],
);`;

const healSnippet = `import { aiFixer } from "jsr:@zuke/ai";

test = target()
  .executes(() => DenoTasks.test((s) => s.allowAll()))
  // On failure: diagnose from the error + diff, post a committable
  // suggestion — or apply, commit, and re-run to verify it goes green.
  .recoverWith(
    aiFixer((f) =>
      f.provider("openai").apiKey(this.key)
        .autoApply()                 // write the fix to the working tree
        .allowPaths("src/**")        // blast-radius allowlist
        .maxEdits(5)                 // …and a file cap
        .commitFixes()               // stage, commit & push to the PR branch
    ),
  )
  .recoverAttempts(2);               // up to two fix-then-rerun cycles`;

const cacheSnippet = `import { Build, HttpCacheStore, cicd, target } from "jsr:@zuke/core";
import { DenoTasks } from "jsr:@zuke/deno";

class CI extends Build {
  // Share built outputs across machines: restore on a local miss, upload
  // after a green run — so the next machine or CI job reuses the work.
  override remoteCache() {
    return new HttpCacheStore({ url: this.cacheUrl.value, token: this.token.value });
  }

  build = target()
    .inputs("src", "deno.json")   // the fingerprint → the cache key
    .outputs("dist")              // archived to / restored from the store
    .executes(() => DenoTasks.run((s) => s.script("build.ts")));

  // One CI job per target, wired by dependsOn — independent jobs run in parallel.
  ci = cicd({ provider: "github", fanOut: true });
}`;

// Remote-cache backends, shown as chips in the caching section.
const cacheBackends = [
  { name: "Filesystem", color: "#34e1d4" },
  { name: "HTTP", color: "#4f8cff" },
  { name: "S3 / GCS / R2", color: "#9b6bff" },
];

const mcpSnippet = `# read-only: an agent can inspect the build, never execute
zuke mcp

# also expose run:<target> tools that execute targets
zuke mcp --allow-run

# register with a client (Claude Code shown; any stdio MCP client works)
claude mcp add zuke -- deno run -A zuke.ts mcp`;

// MCP clients that can drive a Zuke build, shown as chips.
const mcpClients = [
  { name: "Claude Desktop", color: "#d97757" },
  { name: "Claude Code", color: "#d97757" },
  { name: "IDEs", color: "#4f8cff" },
  { name: "Any agent", color: "#9b6bff" },
];

const features = [
  {
    icon: "type",
    title: "Typed, refactor-safe dependencies",
    body: "Targets reference each other with this.target — not magic strings. Rename one and every reference updates. The compiler has your back.",
  },
  {
    icon: "code",
    title: "Just TypeScript",
    body: "Build logic is ordinary async functions with full editor support, types, and debugging. No YAML, no bespoke DSL to learn.",
  },
  {
    icon: "graph",
    title: "Automatic topological order",
    body: "Declare what each target depends on; Zuke resolves the graph and runs everything in the right order, exactly once.",
  },
  {
    icon: "service",
    title: "Long-lived service targets",
    body: "Declare a dev server, database, or mock API with service(). Zuke starts it, waits until it's ready (tcpReachable or your own probe), keeps it alive while dependents run, and stops it in a finally — so a failed test never leaks a process.",
  },
  {
    icon: "ci",
    title: "Code-first CI/CD",
    body: "Declare pipelines with cicd() and generate GitHub Actions, GitLab CI, or Azure Pipelines YAML — verified up to date on every run.",
  },
  {
    icon: "shell",
    title: "Ergonomic, safe shell",
    body: "The $ tagged template executes processes with sensible defaults and prevents injection — capture output, ignore failures, or fail fast.",
  },
  {
    icon: "bolt",
    title: "Incremental, remote & parallel",
    body: "Fingerprint a target's .inputs()/.outputs() to skip unchanged work as cached, share those outputs across machines with a remote cache, scope a run to what changed with --affected, and run independent targets concurrently with --parallel.",
  },
  {
    icon: "jsr",
    title: "A typed tool ecosystem",
    body: `Strongly-typed wrappers for ${packageCount}+ tools — Deno, npm, Bun, Docker, Kubernetes, Helm, Vite, Playwright, Terraform and more — all on JSR.`,
  },
  {
    icon: "download",
    title: "Hermetic, pinned toolchains",
    body: "Fetch the CLIs a build drives with toolchain() or ToolTasks.install() — pinned by SHA-256, verified, and cached. A fresh clone or a bare CI runner is reproducible, with no 'install these first' step.",
  },
  {
    icon: "lock",
    title: "Secrets, sourced & redacted",
    body: "Pull a secret from your manager — 1Password, Vault, gcloud, a mounted file — with .from(execSecret(…)), and Zuke redacts its value from every log, summary, and error, on any platform.",
  },
  {
    icon: "ai",
    title: "AI in your pipeline",
    body: "Typed wrappers for Claude Code, OpenAI Codex, and Gemini CLI run headless in CI — drive a prompt, pick a model, constrain the tools, and capture the output, injection-free.",
  },
  {
    icon: "review",
    title: "AI code-review gate",
    body: "Turn an LLM into a build gate with @zuke/ai — it reads the diff, gets a structured risk assessment, and breaks the build when the score crosses your threshold. Claude, OpenAI, or Gemini.",
  },
  {
    icon: "heal",
    title: "Self-healing builds",
    body: "Attach a fixer with .recoverWith(). When a target fails, @zuke/ai diagnoses it from the command, stderr, and diff, posts a committable suggestion — or auto-applies, commits, and re-runs the real command to verify the build goes green.",
  },
  {
    icon: "announce",
    title: "Announce to chat",
    body: "Post build status to Slack, Microsoft Teams, and Discord from a target with AnnounceTasks — typed messages with levels, fields, and links, over incoming webhooks or each platform's bot API.",
  },
  {
    icon: "plugin",
    title: "Extensible by design",
    body: "Need a tool we don't wrap yet? Extend ToolSettings from @zuke/core/tooling to build your own typed wrapper — no fork required.",
  },
  {
    icon: "zero",
    title: "Zero runtime dependencies",
    body: "Zuke ships on Deno with nothing else to install. The bootstrap launcher even installs Deno for you on first run.",
  },
];

const icons: Record<string, string> = {
  type: `<path d="M4 7V5h16v2M9 5v14m-3 0h6"/>`,
  code: `<path d="m8 8-4 4 4 4M16 8l4 4-4 4"/>`,
  graph: `<circle cx="5" cy="6" r="2.5"/><circle cx="5" cy="18" r="2.5"/><circle cx="13" cy="12" r="2.5"/><circle cx="20" cy="12" r="2.5"/><path d="M7 7.5 10.7 11M7 16.5 10.7 13M15.5 12H17.5"/>`,
  ci: `<path d="M4 6a2 2 0 1 1 4 0 2 2 0 0 1-4 0Zm12 12a2 2 0 1 1 4 0 2 2 0 0 1-4 0ZM6 8v4a4 4 0 0 0 4 4h4"/><path d="M14 14l2 2-2 2"/>`,
  shell: `<path d="m5 8 4 4-4 4M12 16h7"/><rect x="2" y="3" width="20" height="18" rx="3"/>`,
  bolt: `<path d="M13 2 4 14h7l-1 8 9-12h-7z"/>`,
  zero: `<path d="M20 7 12 3 4 7v10l8 4 8-4z"/><path d="M12 12 4 7M12 12v9M12 12l8-5"/>`,
  jsr: `<path d="M4 6h16v12H4z"/><path d="M8 10v4M12 9v6M12 15h2a2 2 0 0 0 0-4M16 10h2"/>`,
  plugin: `<path d="M9 3v4M15 3v4M7 7h10v4a5 5 0 0 1-10 0zM12 16v5"/>`,
  ai: `<rect x="4" y="7" width="16" height="12" rx="2.5"/><path d="M12 7V4M9 12h.01M15 12h.01M9 15.5h6"/><path d="M2 12h2M20 12h2"/>`,
  announce: `<path d="M3 11v2a1 1 0 0 0 1 1h2l4 4V6L6 10H4a1 1 0 0 0-1 1Z"/><path d="M15 9a4 4 0 0 1 0 6M18 6.5a8 8 0 0 1 0 11"/>`,
  review: `<path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/><path d="m9 14 2 2 4-4"/>`,
  heal: `<path d="M20.5 8.5a4.6 4.6 0 0 0-6.5-6.5L12 4 10 2a4.6 4.6 0 0 0-6.5 6.5"/><path d="M3.5 8.5 12 17l4-4"/><path d="M3 14h4l1.5-3 2.5 6 1.5-3H21"/>`,
  download: `<path d="M12 3v11m0 0 4-4m-4 4-4-4"/><path d="M4 16v3a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-3"/>`,
  lock: `<rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/><path d="M12 15v2"/>`,
  service: `<rect x="3" y="4" width="18" height="7" rx="1.6"/><rect x="3" y="13" width="18" height="7" rx="1.6"/><path d="M7 7.5h.01M7 16.5h.01"/>`,
};

// The model providers @zuke/ai supports, shown as chips in the AI review section.
const providers = [
  {
    name: "Claude",
    color: "#d97757",
    // sunburst asterisk
    svg: `<path d="M12 3v18M3 12h18M5.6 5.6l12.8 12.8M18.4 5.6 5.6 18.4"/>`,
  },
  {
    name: "OpenAI",
    color: "#10a37f",
    // hexagon with a node
    svg: `<path d="M12 3.2 18.9 7.1v9.8L12 20.8 5.1 16.9V7.1z"/><circle cx="12" cy="12" r="2.6"/>`,
  },
  {
    name: "Gemini",
    color: "#4f8cff",
    // four-point sparkle
    svg: `<path d="M12 2c.5 5.5 4 9 9.5 9.5-5.5.5-9 4-9.5 9.5-.5-5.5-4-9-9.5-9.5C8 11 11.5 7.5 12 2Z"/>`,
  },
];

// CI hosts @zuke/ai posts PR comments to and generates workflows for.
const hosts = [
  { name: "GitHub", color: "#e6ebf5" },
  { name: "GitLab", color: "#fc6d26" },
  { name: "Azure", color: "#2ea0ee" },
  { name: "Bitbucket", color: "#2684ff" },
];
---

<Base>
  <!-- ░░ HERO ░░ -->
  <section class="hero">
    <div class="container hero__grid">
      <div class="hero__copy">
        <span class="eyebrow">Build automation · Deno &amp; TypeScript</span>
        <h1 class="hero__title">
          Builds you can <span class="gradient-text">refactor</span>,
          not just run.
        </h1>
        <p class="lead">
          Zuke is a code-first, strongly-typed build system. Define targets as
          TypeScript class fields, wire dependencies with a fluent API, and let
          Zuke resolve and run them in topological order — with zero runtime
          dependencies.
        </p>
        <div class="hero__cta">
          <a class="btn btn-primary" href="/docs">Get started →</a>
          <a class="btn btn-ghost" href="https://github.com/zuke-build/zuke" target="_blank" rel="noopener noreferrer">
            View on GitHub
          </a>
        </div>
        <div class="hero__install">
          <CopyBlock
            label="Install the CLI"
            lines={[
              "deno install -A -g -n zuke jsr:@zuke/cli",
              "zuke setup",
              "./zuke",
            ]}
          />
        </div>
      </div>

      <div class="hero__code" data-reveal>
        <div class="codecard panel">
          <div class="codecard__bar">
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__name">zuke.ts</span>
          </div>
          <Code code={heroSnippet} lang="ts" theme="night-owl" />
        </div>
      </div>
    </div>

    <div class="container hero__strip">
      <span><b>v1</b> released</span>
      <span class="dotsep">•</span>
      <span>Deno-native</span>
      <span class="dotsep">•</span>
      <span>Zero runtime deps</span>
      <span class="dotsep">•</span>
      <span>Published on JSR</span>
      <span class="dotsep">•</span>
      <span>Inspired by NUKE for .NET</span>
    </div>
  </section>

  <!-- ░░ FEATURES ░░ -->
  <section class="section" id="features">
    <div class="container">
      <header class="sec-head">
        <span class="eyebrow">Why Zuke</span>
        <h2>Everything a build needs — typed end to end.</h2>
      </header>
      <div class="feat-grid">
        {features.map((f) => (
          <article class="feat panel" data-reveal>
            <span class="feat__icon">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="1.7" stroke-linecap="round"
                stroke-linejoin="round" set:html={icons[f.icon]} />
            </span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ░░ DAG / RESOLUTION ░░ -->
  <section class="section sec-dag" id="resolution">
    <div class="container dag-grid">
      <div data-reveal>
        <span class="eyebrow">Topological resolution</span>
        <h2>Declare dependencies.<br />Zuke figures out the order.</h2>
        <p class="lead">
          Each target lists what it <code>dependsOn</code>. Zuke builds the
          dependency graph, runs independent targets as far as it can, and
          executes everything exactly once in the correct order.
        </p>
        <ul class="ticks">
          <li>References are real values — <code>this.build</code>, never a string.</li>
          <li>Per-target status, timing, and a final build summary.</li>
          <li>Rename a target and every dependant updates automatically.</li>
          <li><a href="/docs/caching">Incremental caching</a> skips a target whose <code>.inputs()</code> are unchanged — reported <code>cached</code>, with dependents still running.</li>
          <li><code>zuke graph --output=html</code> renders an interactive graph you can pan, zoom, and click to trace dependencies.</li>
        </ul>
        <p class="dag-note">
          ↓ The graph that builds this website. See
          <a href="/examples#graph">Zuke's own build graph</a> rendered to HTML.
        </p>
      </div>
      <div data-reveal>
        <DagDiagram />
      </div>
    </div>
  </section>

  <!-- ░░ OUTPUT ░░ -->
  <section class="section sec-out" id="output">
    <div class="container out-grid">
      <div data-reveal>
        <span class="eyebrow">Readable output</span>
        <h2>A build log you can actually scan.</h2>
        <p class="lead">
          Every target is framed with a ruled banner and closes with a plain
          pass/fail line and its duration. The run ends with an aligned
          <strong>Build Summary</strong> — status and timing per target, a total,
          and a one-line verdict stamped with the time. It's all powered by
          <a href="/docs/console"><code>@zuke/console</code></a>, and the same
          primitives are yours to call in any target.
        </p>
        <ul class="ticks">
          <li>Blocks are easy to scan; a failure prints its error inline.</li>
          <li>The summary table totals the wall-clock time across targets.</li>
          <li>
            <a href="/docs/console"><code>@zuke/console</code></a> gives you
            tag-based <code>[bold]</code>/<code>[green]</code> markup plus
            rules, boxes, and tables — a levelled logger for your own output.
          </li>
          <li>GitHub Actions gets matching groups, annotations, and a job-summary table.</li>
        </ul>
      </div>
      <div data-reveal>
        <div class="codecard panel">
          <div class="codecard__bar">
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__name">zuke build</span>
          </div>
<pre class="term"><span class="t-cmd">$ ./zuke build</span>

<span class="t-banner">══════════════════════════════</span>
<span class="t-name">build</span>
<span class="t-banner">══════════════════════════════</span>
<span class="t-dim">  ▸ astro build — 4 pages in 2.2s</span>
<span class="t-ok">✔</span> build <span class="t-dim">succeeded in 2.2s</span>

<span class="t-title">Build Summary</span>
<span class="t-rule">────────────────────────────</span>
<span class="t-head">Target   Status     Duration</span>
<span class="t-rule">────────────────────────────</span>
clean    <span class="t-ok">Succeeded</span>      0.1s
install  <span class="t-ok">Succeeded</span>     12.4s
check    <span class="t-ok">Succeeded</span>      3.1s
build    <span class="t-ok">Succeeded</span>      2.2s
<span class="t-rule">────────────────────────────</span>
<span class="t-total">Total                  17.8s</span>

<span class="t-pass">✔ Build succeeded — 4/4 targets in 17.8s · 2026-06-23 07:19</span></pre>
        </div>
      </div>
    </div>

    <div class="container out-compose" data-reveal>
      <div class="out-compose__intro">
        <h3>Compose the same output in your own targets</h3>
        <p>
          Import <code>@zuke/console</code> and reach for rules, colored markup,
          boxes, and tables directly — the exact primitives the runner uses for
          its banners and summary. <a href="/docs/console">Read the Console output guide →</a>
        </p>
      </div>
      <div class="out-compose__demo">
        <div class="codecard panel">
          <div class="codecard__bar">
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__name">zuke.ts</span>
          </div>
          <Code code={consoleSnippet} lang="ts" theme="night-owl" />
        </div>
        <div class="codecard panel">
          <div class="codecard__bar">
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__name">output</span>
          </div>
<pre class="term"><span class="t-rule">──────────────</span> <span class="t-title">Release</span> <span class="t-rule">──────────────</span>
<span class="t-info">ℹ</span> pushing <span class="t-name">core@1.2.0</span>
<span class="t-ok">✔</span> published 4 packages
<span class="t-warn">⚠</span> coverage <span class="t-warn">94.2%</span> — below gate

<span class="t-box">┌</span> <span class="t-title">Artifacts</span> <span class="t-box">──────────────────┐</span>
<span class="t-box">│</span>  core  1.2.0  <span class="t-ok">✔</span>              <span class="t-box">│</span>
<span class="t-box">│</span>  cli   1.2.0  <span class="t-ok">✔</span>              <span class="t-box">│</span>
<span class="t-box">└──────────────────────────────┘</span>

<span class="t-head">Package      Size</span>
<span class="t-rule">─────────────────</span>
@zuke/core   18 kB
@zuke/cli    12 kB</pre>
        </div>
      </div>
    </div>
  </section>

  <!-- ░░ SHELL ░░ -->
  <section class="section" id="shell">
    <div class="container shell-grid">
      <div class="codecard panel" data-reveal>
        <div class="codecard__bar">
          <span class="codecard__dot"></span>
          <span class="codecard__dot"></span>
          <span class="codecard__dot"></span>
          <span class="codecard__name">shell.ts</span>
        </div>
        <Code code={shellSnippet} lang="ts" theme="night-owl" />
      </div>
      <div data-reveal>
        <span class="eyebrow">The $ shell</span>
        <h2>Run processes without the footguns.</h2>
        <p class="lead">
          The <code>$</code> tagged template from <code>@zuke/core/shell</code>
          escapes interpolations automatically, so untrusted values can't break
          out of a command. Chain <code>.text()</code>, <code>.code()</code>, or
          <code>.noThrow()</code> for exactly the behaviour you want.
        </p>
        <a class="btn btn-ghost" href="/docs">Read the shell guide →</a>
      </div>
    </div>
  </section>

  <!-- ░░ CACHING ░░ -->
  <section class="section sec-cache" id="caching">
    <div class="container cache-grid">
      <div data-reveal>
        <span class="eyebrow">Caching &amp; distributed builds <span class="tag-new">New</span></span>
        <h2>Build it once. <span class="gradient-text">Reuse it everywhere.</span></h2>
        <p class="lead">
          Zuke fingerprints a target's <code>.inputs()</code> and skips it when
          nothing changed. A <strong>remote cache</strong> takes that across
          machines — a fresh checkout or a CI job <strong>restores</strong> a
          target's built outputs from a shared store instead of rebuilding them —
          and <code>--affected</code> narrows a run to just what a change can reach.
        </p>
        <ul class="ticks">
          <li><strong>Incremental, locally</strong> — <code>.inputs()</code>/<code>.outputs()</code> are fingerprinted; an unchanged target is skipped and shown <code>cached</code>.</li>
          <li><strong>Remote cache</strong> — on a local miss, restore a target's outputs from a shared store instead of rebuilding; upload after a green run so the next machine reuses them.</li>
          <li><strong>Two backends</strong> — a mounted directory or any HTTP object store (S3/GCS/R2), via a typed <code>remoteCache()</code> override or <code>ZUKE_REMOTE_CACHE_*</code> in CI.</li>
          <li><strong><code>--affected</code></strong> runs only the targets a git diff can reach, and <strong><code>fanOut</code></strong> emits one parallel CI job per target — the monorepo combo.</li>
        </ul>
        <div class="providers">
          <span class="providers__label">Cache backends</span>
          {cacheBackends.map((b) => (
            <span class="provider" style={`--c:${b.color}`}>
              <span class="host-dot"></span>{b.name}
            </span>
          ))}
        </div>
        <a class="btn btn-ghost" href="/docs/caching">Read the caching guide →</a>
      </div>

      <div class="cache-visual" data-reveal>
        <div class="codecard panel">
          <div class="codecard__bar">
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__name">zuke.ts</span>
          </div>
          <Code code={cacheSnippet} lang="ts" theme="night-owl" />
        </div>

        <!-- the distributed-cache flow: machine A uploads, a CI job restores -->
        <div class="rcache panel">
          <div class="rcache__bar">
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="codecard__dot"></span>
            <span class="rcache__barname">remote cache</span>
