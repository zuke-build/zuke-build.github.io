    width: 100%;
    border-collapse: collapse;
    margin: 18px 0 22px;
    font-size: 0.9rem;
  }
  .dtable th, .dtable td {
    text-align: left;
    padding: 9px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .dtable th { color: var(--text); font-weight: 700; }
  .dtable td { color: var(--text-dim); }
  .dtable :global(code) { font-size: 0.85em; }
</style>
