    font-family: var(--font-mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--cyan);
    background: var(--gradient-soft);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 2px 8px;
    margin-left: 8px;
    vertical-align: middle;
  }
  .dtable {
    width: 100%;
    border-collapse: collapse;
    margin: 18px 0 22px;
    font-size: 0.9rem;
  }
  .dtable th, .dtable td {
    text-align: left;
    padding: 9px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: top;
  }
  .dtable th { color: var(--text); font-weight: 700; }
  .dtable td { color: var(--text-dim); }
