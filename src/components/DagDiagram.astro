---
// Animated dependency graph — the actual target graph of THIS site's build.
// clean ─┐
//        ├─▶ build ─▶ preview
// install ─▶ check ─┘
// Rendered as a constant-dark app window (a "terminal on paper"), one amber
// accent for the live/flowing state — no rainbow, no neon glow.
const nodes = [
  { id: "clean", x: 60, y: 38 },
  { id: "install", x: 60, y: 150 },
  { id: "check", x: 248, y: 150 },
  { id: "build", x: 452, y: 92 },
  { id: "preview", x: 636, y: 92 },
];
const edges = [
  ["install", "check"],
  ["check", "build"],
  ["clean", "build"],
  ["build", "preview"],
];
const byId = Object.fromEntries(nodes.map((n) => [n.id, n]));
const W = 132;
const H = 46;
// edge from right edge of source node to left edge of target node
const path = ([a, b]: string[]) => {
  const s = byId[a], t = byId[b];
  const x1 = s.x + W / 2, y1 = s.y;
  const x2 = t.x - W / 2, y2 = t.y;
  const mx = (x1 + x2) / 2;
  return `M ${x1} ${y1} C ${mx} ${y1}, ${mx} ${y2}, ${x2} ${y2}`;
};
---

<div class="dag" role="img" aria-label="Dependency graph: clean and install feed into check and build, which feeds preview, resolved in topological order.">
  <div class="dag__head">
    <span class="dag__dot"></span><span class="dag__dot"></span><span class="dag__dot"></span>
    <span class="dag__title">zuke · resolving target graph</span>
  </div>
  <svg viewBox="-20 -8 744 200" class="dag__svg" xmlns="http://www.w3.org/2000/svg">
    {edges.map((e, i) => (
      <>
        <path d={path(e)} class="dag__edge" />
        <path d={path(e)} class="dag__flow" style={`animation-delay:${i * 0.5}s`} />
      </>
    ))}

    {nodes.map((n, i) => (
      <g class="dag__node" style={`animation-delay:${i * 0.45}s`}
         transform={`translate(${n.x - W / 2} ${n.y - H / 2})`}>
        <rect width={W} height={H} rx="8" class="dag__box" />
        <circle cx="18" cy={H / 2} r="4.5" class="dag__pulse" />
        <text x="34" y={H / 2 + 5} class="dag__label">{n.id}</text>
      </g>
    ))}
  </svg>
</div>

<style>
  .dag {
    background: var(--term-bg);
    border: 1px solid var(--term-border);
    border-radius: var(--radius);
    padding: 0;
    overflow: hidden;
    box-shadow: var(--shadow-term);
  }
  .dag__head {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 12px 16px;
    border-bottom: 1px solid var(--term-border);
    background: oklch(1 0 0 / 0.02);
  }
  .dag__dot {
    width: 11px;
    height: 11px;
    border-radius: 99px;
    background: var(--term-border);
  }
  .dag__dot:nth-child(1) { background: #ff5f56; }
  .dag__dot:nth-child(2) { background: #ffbd2e; }
  .dag__dot:nth-child(3) { background: #27c93f; }
  .dag__title {
    margin-left: 8px;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--term-faint);
  }
  .dag__svg {
    display: block;
    width: 100%;
    height: auto;
    padding: 22px 18px 26px;
  }

  .dag__edge {
    fill: none;
    stroke: var(--term-border);
    stroke-width: 2;
  }
  .dag__flow {
    fill: none;
    stroke: var(--term-accent);
    stroke-width: 2.4;
    stroke-linecap: round;
    stroke-dasharray: 10 220;
    animation: flow 2.4s linear infinite;
  }
  @keyframes flow {
    to { stroke-dashoffset: -230; }
  }

  .dag__box {
    fill: var(--term-raised);
    stroke: var(--term-border);
    stroke-width: 1.5;
    animation: pop 0.5s ease both;
  }
  .dag__label {
    fill: var(--term-ink);
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 500;
  }
  .dag__pulse {
    fill: var(--term-accent);
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pop {
    from { opacity: 0; transform: translateY(6px); }
  }
  @keyframes pulse {
    0%, 100% { opacity: 0.55; }
    50% { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .dag__flow, .dag__box, .dag__pulse { animation: none; }
    .dag__flow { stroke-dasharray: none; opacity: 0.85; }
  }

  /* On narrow screens, scroll the graph horizontally so node labels stay
     legible rather than scaling down to an unreadable size. */
  @media (max-width: 560px) {
    .dag { overflow-x: auto; overflow-y: hidden; }
    .dag__svg { min-width: 460px; }
  }
</style>
