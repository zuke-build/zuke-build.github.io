---
import { Image } from "astro:assets";
import logoWhite from "../assets/logo-white.png";
import logoColor from "../assets/logo.png";

interface Props {
  /** rendered height in px; width scales to the logo's aspect ratio */
  height?: number;
}
const { height = 44 } = Astro.props;
const wWidth = Math.round((logoWhite.width / logoWhite.height) * height);
const cWidth = Math.round((logoColor.width / logoColor.height) * height);
---

<span class="logo">
  <Image
    src={logoWhite}
    alt="Zuke"
    height={height}
    width={wWidth}
    densities={[1.5, 2]}
    loading="eager"
    class="logo__img logo__img--onDark"
  />
  <Image
    src={logoColor}
    alt="Zuke"
    height={height}
    width={cWidth}
    densities={[1.5, 2]}
    loading="eager"
    class="logo__img logo__img--onLight"
  />
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
  }
  /* All display logic is :global — the <img> that <Image> renders can't be
     reached by Astro's scoped selectors, and a scoped `.logo__img` rule would
     out-specify the global hide. Keep every rule at the same low specificity.
     dark (default): the white lockup. light: the full-color mascot lockup. */
  :global(.logo__img) { height: auto; width: auto; }
  :global(.logo__img--onDark) { display: block; }
  :global(.logo__img--onLight) { display: none; }
  :global(:root[data-theme="light"] .logo__img--onDark) { display: none; }
  :global(:root[data-theme="light"] .logo__img--onLight) { display: block; }
</style>
