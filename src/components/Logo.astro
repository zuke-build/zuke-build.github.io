---
interface Props {
  size?: number;
  withWordmark?: boolean;
}
const { size = 30, withWordmark = true } = Astro.props;
const uid = "lg" + Math.random().toString(36).slice(2, 7);
---

<span class="logo" style={`--s:${size}px`}>
  <svg width={size} height={size} viewBox="0 0 48 48" fill="none" aria-hidden="true">
    <defs>
      <linearGradient id={uid} x1="6" y1="4" x2="42" y2="44" gradientUnits="userSpaceOnUse">
        <stop stop-color="#34e1d4"></stop>
        <stop offset="0.5" stop-color="#4f8cff"></stop>
        <stop offset="1" stop-color="#9b6bff"></stop>
      </linearGradient>
    </defs>
    <rect x="3" y="3" width="42" height="42" rx="12" stroke={`url(#${uid})`} stroke-width="2.5"></rect>
    <!-- a stylised "Z" built from stacked build layers -->
    <path
      d="M15 16 H33 L17 32 H33"
      stroke={`url(#${uid})`}
      stroke-width="3.4"
      stroke-linecap="round"
      stroke-linejoin="round"
      fill="none"></path>
    <circle cx="15" cy="16" r="2.4" fill="#34e1d4"></circle>
    <circle cx="33" cy="32" r="2.4" fill="#9b6bff"></circle>
  </svg>
  {withWordmark && <span class="logo__word">zuke</span>}
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }
  .logo__word {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: calc(var(--s) * 0.62);
    letter-spacing: -0.02em;
    color: var(--text);
  }
</style>
