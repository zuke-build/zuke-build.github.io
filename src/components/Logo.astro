---
import { Image } from "astro:assets";
import logoWhite from "../assets/logo-white.png";

interface Props {
  /** rendered height in px; width scales to the logo's aspect ratio */
  height?: number;
}
const { height = 28 } = Astro.props;
const width = Math.round((logoWhite.width / logoWhite.height) * height);
---

<span class="logo">
  <Image
    src={logoWhite}
    alt="Zuke"
    height={height}
    width={width}
    densities={[1.5, 2]}
    loading="eager"
    class="logo__img"
  />
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
  }
  .logo__img {
    display: block;
    height: var(--logo-h, auto);
    width: auto;
  }
</style>
