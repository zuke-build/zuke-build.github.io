---
import Logo from "./Logo.astro";
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === "/" ? pathname === "/" : pathname.startsWith(href);
const links = [
  { href: "/docs", label: "Docs" },
  { href: "/examples", label: "Examples" },
];
---

<header class="nav" id="site-nav">
  <div class="container nav__inner">
    <a href="/" class="nav__brand" aria-label="Zuke home">
      <Logo height={40} />
    </a>

    <nav class="nav__links" aria-label="Primary">
      {links.map((l) => (
        <a href={l.href} class:list={["nav__link", { active: isActive(l.href) }]}>
          {l.label}
        </a>
      ))}
      <a class="nav__link" href="https://jsr.io/@zuke" target="_blank" rel="noopener noreferrer">JSR</a>

      <span class="nav__sep" aria-hidden="true"></span>

      <button class="nav__theme" id="theme-toggle" type="button" aria-label="Toggle color theme">
        <svg class="nav__sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"></path>
        </svg>
        <svg class="nav__moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8Z"></path>
        </svg>
      </button>

      <a
        class="nav__gh"
        href="https://github.com/zuke-build/zuke"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Zuke on GitHub"
      >
        <svg width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
          <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
        </svg>
      </a>
      <a
        class="nav__gh"
        href="https://x.com/zukebuild"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Zuke on X"
      >
        <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
        </svg>
      </a>
    </nav>
  </div>
</header>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: var(--z-sticky);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    background: color-mix(in oklch, var(--bg) 80%, transparent);
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .nav.scrolled {
    border-bottom-color: var(--border);
  }
  .nav__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 68px;
  }
  .nav__brand { display: inline-flex; }
  .nav__links {
    display: flex;
    align-items: center;
    gap: 22px;
  }
  .nav__link {
    color: var(--ink-dim);
    font-size: 0.92rem;
    font-weight: 500;
  }
  .nav__link:hover { color: var(--ink); }
  .nav__link.active { color: var(--accent); }

  .nav__sep {
    width: 1px;
    height: 20px;
    background: var(--border);
  }

  .nav__theme {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    padding: 0;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--ink-dim);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }
  .nav__theme:hover { color: var(--ink); border-color: var(--border-strong); }
  /* show sun in light mode, moon in dark mode */
  .nav__moon { display: none; }
  .nav__sun { display: block; }
  :root:not([data-theme="light"]) .nav__sun { display: none; }
  :root:not([data-theme="light"]) .nav__moon { display: block; }

  .nav__gh {
    color: var(--ink-dim);
    display: inline-flex;
  }
  .nav__gh:hover { color: var(--ink); }

  @media (max-width: 560px) {
    .nav__inner { height: 60px; }
    .nav__links { gap: 16px; }
    .nav__link[href="https://jsr.io/@zuke"] { display: none; }
  }
  @media (max-width: 380px) {
    .nav__links { gap: 13px; }
    .nav__link { font-size: 0.88rem; }
  }
</style>

<script>
  const nav = document.getElementById("site-nav");
  const onScroll = () => nav?.classList.toggle("scrolled", window.scrollY > 8);
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });

  const toggle = document.getElementById("theme-toggle");
  const meta = document.querySelector('meta[name="theme-color"]');
  toggle?.addEventListener("click", () => {
    const next =
      document.documentElement.dataset.theme === "light" ? "dark" : "light";
    document.documentElement.dataset.theme = next;
    try {
      localStorage.setItem("theme", next);
    } catch {
      /* storage unavailable */
    }
    meta?.setAttribute("content", next === "light" ? "#f7f7f9" : "#16130d");
  });
</script>
